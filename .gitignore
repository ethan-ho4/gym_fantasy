# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# local env files (never commit real keys)
.env
.env.*
!.env.example
.env*.local

# local IDE and agent state
.cursor/
.claude/settings.local.json

# Supabase local state and secrets
supabase/.temp/
supabase/.branches/
supabase/.env
supabase/.env.*

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
